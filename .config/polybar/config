[colors]
include-file = ~/.config/polybar/colours

[bar/main]
override-redirect = false
wm-restack = bspwm
width = 100%
height = 24
offset-x = 0
offset-y = 0
radius = 0.0
fixed-center = true

background = ${colors.transparent}
foreground = ${colors.color15}

line-size = 0
label-line-color = ${colors.transparent}

border-color = ${colors.transparent}
border-top-size = 0
border-left-size = 0
border-right-size = 0

padding-left = 0
padding-right = 0

module-margin-left = 0
module-margin-right = 0

font-0 = Iosevka Nerd Font:size=10;1
font-1 = Victor Mono Nerd Font:size=10:weight=Medium;1
font-2 = Victor Mono Nerd Font:size=10:style=Italic:weight=Medium;1

locale = en_GB.UTF-8
enable-ipc = true

modules-left = time date gap mood
modules-center = bspwm gap xwindow
modules-right = battery gap wlan eth netact gap memory cpu temperature gap backlight volume

tray-position = none
tray-padding = 10
tray-background = ${colors.inactive}

[module/memory]
type = internal/memory
interval = 1

format = <label>
label =   %percentage_used%%
label-padding = 1
label-font = 2
label-foreground = ${colors.foreground}
label-background = ${colors.color1}

[module/cpu]
type = internal/cpu
interval = 1

format = <label>
label =   %percentage%%
label-padding = 1
label-font = 2
label-foreground = ${colors.foreground}
label-background = ${colors.color5}

[module/temperature]
type = internal/temperature
interval = 1

thermal-zone = 0
base-temperature = 35
warn-temperature = 80

format = <label>
units = true
format-warn = <label-warn>

label =  %temperature-c%
label-padding = 1
label-font = 2
label-foreground = ${colors.foreground}
label-background = ${colors.color2}
label-warn =  %temperature-c%
label-warn-padding = 1
label-warn-foreground = ${colors.foreground}
label-warn-background = ${colors.color2}

[module/backlight]
type = internal/backlight
card = intel_backlight

format = <label>
label =   %percentage%%
label-padding = 1
label-font = 2
label-background = ${colors.inactive}
label-foreground = ${colors.foreground}

[module/bspwm]
type = internal/bspwm
pin-workspaces = true
inline-mode = false
enable-click = true
enable-scroll = true
reverse-scroll = true
fuzzy-match = false

ws-icon-0 = 1;    
ws-icon-1 = 2;    
ws-icon-2 = 3;    
ws-icon-3 = 4;    
ws-icon-4 = 5;    
ws-icon-5 = 7;  華  
ws-icon-7 = 8;    
ws-icon-6 = 9;    
ws-icon-8 = 10;    
ws-icon-default =     

format = <label-state>
label-monitor = %name%

label-dimmed-foreground = ${colors.inactive}
label-dimmed-background = ${colors.transparent}

label-focused = %icon%
label-focused-foreground = ${colors.color15}
label-focused-background = ${colors.color2}

label-occupied = %icon%
label-occupied-foreground = ${colors.color15}
label-occupied-background= ${colors.active}

label-urgent = %icon%
label-urgent-foreground = ${colors.color15}
label-urgent-background = ${colors.color4}

label-empty = %icon%
label-empty-foreground = ${colors.color15}
label-empty-background = ${colors.inactive}

label-separator-padding = 0
label-separator-foreground = ${colors.transparent}

[module/gap]
type = custom/text
content = -
content-background = ${colors.transparent}
content-foreground = ${colors.transparent}
content-padding = 0

[module/mood]
type = custom/script
exec = head -n1 ~/.config/polybar/mood
interval = 1
format = <label>
format-background = ${colors.color2}
format-foreground = ${colors.color15}
format-padding = 1
label =   %output:0:30:...%
label-font = 3
click-left = theme_selector

[module/xwindow]
type = internal/xwindow
format-background = ${colors.highlight}
format-padding = 1
label = %title:0:30: ...%
label-font = 3

[module/netact]
type = internal/network
interface = ${file:~/.config/polybar/netadpt}
interval = 1.0

format-connected = <label-connected>
format-connected-padding = 1
format-connected-background = ${colors.active}
format-connected-foreground = ${colors.foreground}

format-disconnected =

label-connected = "  %downspeed%    %upspeed%"
label-connected-font = 2

[module/wlan]
type = internal/network
interface = wlp4s0
interval = 1

format-connected-padding = 1
format-connected = <ramp-signal> <label-connected>
label-connected = %essid%
label-connected-font = 2
format-connected-background = ${colors.color5}

format-disconnected =

ramp-signal-0 = 
ramp-signal-foreground = ${colors.foreground}

[module/eth]
type = internal/network
interface = enp3s0
interval = 3.0

format-connected = <label-connected>
format-connected-padding = 1
format-connected-background = ${colors.inactive}
label-connected = " "
label-connected-font = 2

[module/time]
type = internal/date
interval = 1

time = "  %I:%M %p"

format-padding = 1
format-background = ${colors.active}

label = %time%
label-font = 2

[module/date]
type = internal/date
interval = 1

date = "  %A, %d %B"

format-padding = 1
format-background = ${colors.inactive}

label = %date%
label-font = 2

[module/volume]
type = internal/pulseaudio
use-ui-max = false

label-volume-font = 2
format-volume = <ramp-volume> <label-volume>
format-volume-padding = 1
format-volume-background = ${colors.active}
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
ramp-volume-3 = 
ramp-volume-foreground = ${colors.foreground}

format-muted-prefix = " "
format-muted-foreground = ${colors.color15}
format-muted-background = ${colors.error}
label-muted = MUTE
label-muted-font = 2
format-muted-padding = 1

[module/battery]
type = internal/battery
battery = BAT1
adapter = ACAD
full-at = 95

format-charging = <animation-charging> <label-charging>
format-charging-padding = 1
format-discharging-padding = 1
format-discharging = <ramp-capacity> <label-discharging>
format-full =
label-charging-font = 2
label-discharging-font = 2

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 
ramp-capacity-foreground = ${colors.foreground}

animation-charging-foreground = ${colors.foreground}
animation-charging-framerate = 500
animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
format-charging-background = ${colors.inactive}
format-discharging-background = ${colors.active}

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
