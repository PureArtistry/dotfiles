* {
    background-color: @my-inactive;
    text-color: @my-colour7;
    border: 0;
    padding: 0;
}

#window {
    children: [ message, listview, inputbar ];
    width: 460px;
    height: 383px;
    location: 0;
    y-offset: 80;
}

message {
    children: [ textbox ];
    font: "Iosevka Nerd Font 7";
    background-color: @my-active;
}

textbox {
    text-color: @my-colour7;
    background-color: @my-active;
    padding: 8;
    horizontal-align: 0.5;
    vertical-align: 0.5;
}

listview {
}

element-text {
    font: "Iosevka Nerd Font 16";
    padding: 6px;
    vertical-align: 0.5;
}

element selected {
    background-color: @my-colour2;
}

element urgent {
    background-color: @my-colour4;
}

element active {
    background-color: @my-colour1;
}

inputbar {
    children: [ prompt ];
    background-color: @my-colour4;
}

prompt {
    text-color: @my-colour7;
    background-color: @my-colour4;
    vertical-align: 0.5;
    padding: 4px 8px 4px 8px;
}

