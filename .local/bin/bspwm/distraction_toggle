#!/bin/sh

# toggle distraction windows on home workspace

dazzle_me() {
    bspc subscribe node_add -c 1 &
    art_show
    wait
    [ -f /tmp/pretty_colours_id ] && rm -f /tmp/pretty_colours_id
    bspc subscribe node_add -c 1 &
    sleep 0.01
    new_term --class 'pretty colours','pretty colours' --title 'pretty colours' \
        -e ncmpcpp -c $XDG_CONFIG_HOME/ncmpcpp/config.viz
    sleep 0.05
    wait
    pretty_colours_id=$(xwininfo -root -children | grep -w "pretty colours" | awk '{print $1}')
    echo $pretty_colours_id >/tmp/pretty_colours_id
    bspc subscribe node_add -c 1 &
    fancy_launch
    wait
    feng_shui
    exit
}

plz_stop() {
    STOP_KILLING_RANDOM_SHIT "pretty colours"
    STOP_KILLING_RANDOM_SHIT "fancy writing"
    kill $(head -n1 /tmp/art_show_id)
    rm -f /tmp/kitty_control
    rm -f /tmp/fancy_writing_id
    rm -f /tmp/pretty_colours_id
    rm -f /tmp/pretty_colours_mode
    rm -f /tmp/art_show_id
    exit
}

[ "$1" = "off" ] && plz_stop
[ -f /tmp/fancy_writing_id ] && plz_stop || dazzle_me
