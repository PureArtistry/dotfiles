#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
y=$(acpi -V)
z=$(echo "$y" | head -n1)

b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)
s=72

[ "$(echo "$y" | sed -n 3p | awk '{print $3}')" = 'on-line' ] && ac=1 || ac=0
bp=$(echo "$z" | awk '{print $4}' | sed 's/%//;s/,//')
ctr=$(echo "$z" | sed 's/.*: //' | awk -F ',' '{print $3}' | sed 's/ //')
cs=$(echo "$z" | sed 's/.*: //' | awk '{print $1}' | sed 's/,//')

if [ "$bp" -le 10 ]; then
    [ "$ac" = 1 ] && icon='’¢ģ' || icon='’¢é'
elif [ "$bp" -le 25 ] && [ "$bp" -gt 10 ]; then
    [ "$ac" = 1 ] && icon='’¢å' || icon='’Ģ║'
elif [ "$bp" -le 40 ] && [ "$bp" -gt 25 ]; then
    [ "$ac" = 1 ] && icon='’¢ć' || icon='’Ģ╝'
elif [ "$bp" -le 60 ] && [ "$bp" -gt 40 ]; then
    [ "$ac" = 1 ] && icon='’¢ł' || icon='’ĢŠ'
elif [ "$bp" -le 80 ] && [ "$bp" -gt 60 ]; then
    [ "$ac" = 1 ] && icon='’¢ē' || icon='’¢Ć'
elif [ "$bp" -le 94 ] && [ "$bp" -gt 80 ]; then
    [ "$ac" = 1 ] && icon='’¢Ŗ' || icon='’¢ü'
elif [ "$bp" -gt 94 ]; then
    if [ "$ac" = 1 ]; then
        case "$cs" in
        Unknown*) [ -n "$ctr" ] && icon='’¢ä' || icon='’«Ż' ;;
        Charging*) icon='’¢ä' ;;
        *) icon='’¢É' ;;
        esac
    else
        icon='’ĢĖ'
    fi
else
    icon='’¢É'
fi

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "$s" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

[ ! "$ctr" ] && [ "$bp" -gt 94 ] && msg="Fully Charged" || msg="Remaining Unknown"
[ -n "$ctr" ] && msg="$ctr"

i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment "center" &
dunstify -r "$i" -t 6000 -a 'fancy1' "$bp%" "$msg" -i /tmp/dunst_icon.png
sleep 4
dunstify -C "$i"
killall -q dunst
