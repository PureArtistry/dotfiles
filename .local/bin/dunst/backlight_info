#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
y=$(xbacklight -get)
z=$(echo "$y" | head -n1)

b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)
s=72

if [ "$y" -le 25 ]; then
    icon=''
elif [ "$y" -gt 25 ] && [ "$y" -lt 50 ]; then
    icon=''
elif [ "$y" -ge 50 ] && [ "$y" -lt 75 ]; then
    icon=''
else
    icon=''
fi

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "$s" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment "center" &
dunstify -r "$i" -t 6000 -a 'fancy1' "$y%" "backlight intensity" -i /tmp/dunst_icon.png
sleep 4
dunstify -C "$i"
killall -q dunst
