#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf)
b=$(echo "$x" | awk 'NR==20{print $2}')
f=$(echo "$x" | awk 'NR==2{print $2}')
bd=$(echo "$x" | awk 'NR==18{print $2}')

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize '60' \
    -font 'Iosevka-Nerd-Font-Complete' \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 '' \
    /tmp/dunst_icon.png >/dev/null 2>&1

[ -f /tmp/yt_title ] && msg=$(head -n1 /tmp/yt_title) \
    || msg=$(echo "$1" | awk -F '/' '{print $NF}')
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment "center" &
dunstify -r 43224 -t 6000 -a 'fancy1' 'ready!' "$msg" -i /tmp/dunst_icon.png
sleep 4
dunstify -C 43224
killall -q dunst
[ -f /tmp/yt_title ] && rm -f /tmp/yt_title
return 0
