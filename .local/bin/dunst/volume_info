#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf)
y=$(pactl list sink-inputs)
z=$(pactl list sinks)

b=$(echo "$x" | awk 'NR==20{print $2}')
f=$(echo "$x" | awk 'NR==2{print $2}')
bd=$(echo "$x" | awk 'NR==18{print $2}')
s=72

v=$(echo "$z" | grep -m 1 'Volume:' | awk -F '/' '{print $2}' | sed 's/ //g;s/%//')
vm=$(echo "$y" | grep 'Volume:' | awk -F '/' '{print $2}' | sed 's/ //g;s/%//')
m=$(echo "$z" | grep 'Mute:' | awk '{print $2}')
p=$(echo "$z" | grep 'Active Port:' | awk '{print $3}' | sed 's/analog-output-//g')
an=$(echo "$y" | grep 'application.name =' | sed 's/.*= //;s/"//g')
mc=$(echo "$an" | wc -l)

pick_icon() {
    if [ "$m" = 'yes' ] && [ "$2" = 1 ]; then
        vi='婢'
        msg="MUTE"
    elif [ "$1" = 0 ]; then
        vi=''
    elif [ "$1" -le 33 ] && [ "$1" != 0 ]; then
        vi='奔'
    elif [ "$1" -gt 33 ] && [ "$1" -le 66 ]; then
        vi='墳'
    elif [ "$1" -gt 66 ]; then
        vi=''
    fi
    return
}

make_icon() {
    convert -size 90x90 xc:"$b" \
        -gravity center \
        -pointsize "$s" \
        -font "Iosevka-Nerd-Font-Complete" \
        -fill "$f" \
        -bordercolor "$bd" \
        -border '5' \
        -annotate +0+0 "$vi" \
        /tmp/"$1".png >/dev/null 2>&1
    return
}

pick_icon "$v" 1
make_icon dunst_icon0

if [ -n "$an" ]; then
    if [ "$mc" -gt 1 ]; then
        c=1
        until [ "$c" -gt "$mc" ]; do
            l=$(echo "$vm" | sed -n "$c"p)
            pick_icon "$l"
            make_icon dunst_icon"$c"
            c=$((${c} + 1))
        done
    else
        pick_icon "$vm"
        make_icon dunst_icon1
    fi
fi

pgrep dunst >/dev/null && killall -q dunst
dunst -geometry "380x3-4+4" -alignment "center" &
i=$(shuf -i 1-10000 -n 1)
dunstify -r "$i" -t 6000 -a 'fancy1' "$v%" "$p" -i /tmp/dunst_icon0.png

if [ -n "$an" ]; then
    sleep 3
    if [ "$mc" -gt 1 ]; then
        c=1
        until [ "$c" -gt "$mc" ]; do
            l=$(echo "$an" | sed -n "$c"p)
            k=$(echo "$vm" | sed -n "$c"p)
            dunstify -r "$i" -t 6000 -a 'fancy1' "$k%" "$l" -i /tmp/dunst_icon"$c".png
            sleep 3
            c=$((${c} + 1))
        done
    else
        dunstify -r "$i" -t 6000 -a 'fancy1' "$vm%" "$an" -i /tmp/dunst_icon1.png
        sleep 3
    fi
else
    sleep 4
fi

dunstify -C "$i"
killall -q dunst
