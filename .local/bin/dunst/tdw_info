#!/bin/sh

if [ -n "$1" ]; then
    net=0
    fw=1
else
    nc -z -w 1 8.8.8.8 53 >/dev/null 2>&1
    net=$?
fi

if [ "$net" -eq 0 ]; then
    r=$(curl -s wttr.in/\?format=j1)
    echo "$r" | jq >/dev/null 2>&1
    reh=$?
    if [ "$reh" -eq 0 ]; then
        w=$(echo "$r" | jq -r '.current_condition[0].weatherDesc[0].value')
        t=$(echo "$r" | jq -r '.current_condition[0].temp_C')
        ws=$(echo "$r" | jq -r '.current_condition[0].windspeedMiles')
        dn=$(date +"%H")

        if [ "$ws" -le 1 ]; then
            wd='Calm'
        elif [ "$ws" -gt 1 ] && [ "$ws" -le 3 ]; then
            wd='Light air'
        elif [ "$ws" -gt 3 ] && [ "$ws" -le 7 ]; then
            wd='Light breeze'
        elif [ "$ws" -gt 7 ] && [ "$ws" -le 12 ]; then
            wd='Gentle breeze'
        elif [ "$ws" -gt 12 ] && [ "$ws" -le 18 ]; then
            wd='Moderate breeze'
        elif [ "$ws" -gt 18 ] && [ "$ws" -le 24 ]; then
            wd='Fresh breeze'
        elif [ "$ws" -gt 24 ] && [ "$ws" -le 31 ]; then
            wd='Strong winds'
        elif [ "$ws" -gt 31 ]; then
            wd='Fuck THAT!'
        fi

        case "$w" in
        Clear*)
            s=58
            if [ "$ws" -lt 20 ]; then
                if [ "$dn" -le 5 ] || [ "$dn" -ge 20 ]; then
                    icon="пӘ“"
                    s=72
                else
                    icon="оҢҚ"
                fi
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="пӘң" || icon="оҚҪ"
            fi
            ;;
        Sunny*)
            s=48
            if [ "$ws" -lt 20 ]; then
                if [ "$dn" -le 5 ] || [ "$dn" -ge 20 ]; then
                    icon="оҚҚ"
                else
                    s=56
                    icon="оҢҚ"
                fi
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="пӘң" || icon="оҚҪ"
            fi
            ;;
        "Partly cloudy"*)
            s=72
            if [ "$ws" -lt 20 ]; then
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҚ№" || icon="пӘ”"
            else
                s=48
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢҹ" || icon="оҢҖ"
            fi
            ;;
        Cloudy*)
            s=48
            if [ "$ws" -lt 20 ]; then
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҚҫ" || icon="оҢӮ"
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢ " || icon="оҢҒ"
            fi
            ;;
        Overcast*)
            s=52
            if [ "$ws" -lt 20 ]; then
                if [ "$dn" -le 5 ] || [ "$dn" -ge 20 ]; then
                    s=56
                    icon="оҢ®"
                else
                    icon="оҢӮ"
                fi
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢҹ" || icon="оҢҖ"
            fi
            ;;
        Mist* | Fog* | "Freezing fog"* | "Shallow fog"* | Haze*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҚҶ" || icon="оҢғ"
            ;;
        "Moderate or heavy rain with thunder"*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢӘ" || icon="оҢҸ"
            ;;
        "Patchy light snow with thunder"* | "Moderate or heavy snow with thunder"*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҚ§" || icon="оҚҘ"
            ;;
        "Patchy light rain with thunder"* | "Thundery outbreaks possible"* | "Thunderstorm in vicinity"*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢў" || icon="оҢ…"
            ;;
        "Patchy rain possible"* | "Patchy light rain"* | "Light rain"* | "Shower in vicinity"* | "Rain shower"*)
            s=54
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢЁ" || icon="оҢӢ"
            ;;
        "Patchy snow possible"* | "Blowing snow"* | "Light snow"* | "Patchy light snow"*)
            s=48
            if [ "$ws" -lt 20 ]; then
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢ§" || icon="оҢҠ"
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҚЎ" || icon="оҚҹ"
            fi
            ;;
        "Patchy sleet possible"* | "Light sleet"* | "Moderate or heavy sleet"*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҺ¬" || icon="оҺӘ"
            ;;
        "Patchy freezing drizzle possible"* | "Freezing drizzle"* | "Light freezing rain"*)
            s=48
            if [ "$ws" -lt 20 ]; then
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢҰ" || icon="оҢҶ"
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢӨ" || icon="оҢҮ"
            fi
            ;;
        Blizzard*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="пӢң" || icon="пӢң"
            ;;
        "Patchy light drizzle"* | "Light drizzle"* | "Drizzle"*)
            s=52
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢҙ" || icon="оҢү"
            ;;
        "Heavy freezing drizzle"* | "Heavy rain"* | "Moderate or heavy freezing rain"* | "Torrential rain shower"*)
            s=72
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="пӘ•" || icon="пӘ•"
            ;;
        "Moderate rain"* | "Moderate or heavy rain shower"* | "Rain")
            s=54
            if [ "$ws" -lt 20 ]; then
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢҘ" || icon="оҢҲ"
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢӨ" || icon="оҢҮ"
            fi
            ;;
        "Patchy moderate snow"* | "Moderate snow"* | "Patchy heavy snow"* | "Heavy snow"* | "Moderate or heavy snow showers"*)
            s=48
            if [ "$ws" -lt 20 ]; then
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢ§" || icon="оҢҠ"
            else
                [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҚЎ" || icon="оҚҹ"
            fi
            ;;
        "Ice pellets"*)
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="оҢЎ" || icon="оҢ„"
            ;;
        *)
            s=72
            icon="оҚҙ"
            ;;
        esac
    else
        if [ -n "$fw" ]; then
            echo "пҒұ  weather info unavailable"
            exit
        fi
    fi
else
    s=72
    icon='пңҒ'
fi

if [ -n "$fw" ]; then
    [ "$s" -gt 55 ] && echo "$icon  $w ($tВ°C)" || echo "$icon   $w ($tВ°C)"
    exit
fi

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf)
b=$(echo "$x" | awk 'NR==20{print $2}')
f=$(echo "$x" | awk 'NR==2{print $2}')
bd=$(echo "$x" | awk 'NR==18{print $2}')

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "$s" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

pgrep dunst >/dev/null && killall -q dunst
[ ! "$w" ] && unset r
if [ ! "$r" ]; then
    dunst -shrink -alignment "center" &
else
    dunst -geometry "410x3-4+4" -alignment "center" &
fi
d=$(date +"%A %d %B")
i=$(shuf -i 1-10000 -n 1)
z=0
c=8
until [ "$z" = "$c" ]; do
    dunstify -r "$i" -t 6000 -a 'fancy1' "$(date +'%H:%M:%S')" "$d" \
        -i /tmp/dunst_icon.png
    sleep 0.5
    z=$((${z} + 1))
done
if [ -n "$r" ]; then
    t=$(echo "$t" | sed 's/-/пҒЁ /')
    dunstify -r "$i" -t 6000 -a 'fancy1' "$tВ°C" "$w" \
        -i /tmp/dunst_icon.png
    sleep 3
    dunstify -r "$i" -t 6000 -a 'fancy1' "$ws mph" "$wd" \
        -i /tmp/dunst_icon.png
    sleep 3
fi
dunstify -C "$i"
killall -q dunst
