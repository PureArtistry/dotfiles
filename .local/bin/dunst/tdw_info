#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)

nc -z -w 1 8.8.8.8 53 >/dev/null 2>&1
net=$?
if [ "$net" -eq 0 ]; then
    r=$(curl wttr.in/\?format=j1)
    w=$(echo "$r" | jq -r '.current_condition[0].weatherDesc[0].value')
    t=$(echo "$r" | jq -r '.current_condition[0].temp_C')
    ws=$(echo "$r" | jq -r '.current_condition[0].windspeedMiles')
    dn=$(date +"%H")

    if [ "$ws" -le 1 ]; then
        wd='Calm'
    elif [ "$ws" -gt 1 ] && [ "$ws" -le 3 ]; then
        wd='Light air'
    elif [ "$ws" -gt 3 ] && [ "$ws" -le 7 ]; then
        wd='Light breeze'
    elif [ "$ws" -gt 7 ] && [ "$ws" -le 12 ]; then
        wd='Gentle breeze'
    elif [ "$ws" -gt 12 ] && [ "$ws" -le 18 ]; then
        wd='Moderate breeze'
    elif [ "$ws" -gt 18 ] && [ "$ws" -le 24 ]; then
        wd='Fresh breeze'
    elif [ "$ws" -gt 24 ] && [ "$ws" -le 31 ]; then
        wd='Strong winds'
    elif [ "$ws" -gt 31 ]; then
        wd='Fuck THAT!'
    fi

    case "$w" in
    Clear*)
        s=72
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="якУ" || icon="юМН"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="якЬ" || icon="юН╜"
        fi
        ;;
    Sunny*)
        s=48
        if [ "$ws" -lt 20 ]; then
            if [ "$dn" -le 5 ] || [ "$dn" -ge 21 ]; then
                icon="юНН"
            else
                s=60
                icon="юМН"
            fi
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="якЬ" || icon="юН╜"
        fi
        ;;
    "Partly cloudy"*)
        s=72
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юН╣" || icon="якФ"
        else
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМЯ" || icon="юМА"
        fi
        ;;
    Cloudy*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юН╛" || icon="юМВ"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМа" || icon="юМБ"
        fi
        ;;
    Overcast*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМо" || icon="юМВ"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМЯ" || icon="юМА"
        fi
        ;;
    Mist* | Fog* | "Freezing fog"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юНЖ" || icon="юМГ"
        ;;
    "Moderate or heavy rain with thunder"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМк" || icon="юМП"
        ;;
    "Patchy light snow with thunder"* | "Moderate or heavy snow with thunder"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юНз" || icon="юНе"
        ;;
    "Patchy light rain with thunder"* | "Thundery outbreaks possible"* | "Thunderstorm in vicinity"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМв" || icon="юМЕ"
        ;;
    "Patchy rain possible"* | "Patchy light rain"* | "Light rain"* | "Shower in vicinity"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМи" || icon="юМЛ"
        ;;
    "Patchy snow possible"* | "Blowing snow"* | "Light snow"* | "Patchy light snow"*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМз" || icon="юМК"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юНб" || icon="юНЯ"
        fi
        ;;
    "Patchy sleet possible"* | "Light sleet"* | "Moderate or heavy sleet"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юОм" || icon="юОк"
        ;;
    "Patchy freezing drizzle possible"* | "Freezing drizzle"* | "Light freezing rain"*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМж" || icon="юМЖ"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМд" || icon="юМЗ"
        fi
        ;;
    Blizzard*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="яЛЬ" || icon="яЛЬ"
        ;;
    "Patchy light drizzle"* | "Light drizzle"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМ┤" || icon="юМЙ"
        ;;
    "Heavy freezing drizzle"* | "Heavy rain"* | "Moderate or heavy freezing rain"* | "Torrential rain shower"*)
        s=72
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="якХ" || icon="якХ"
        ;;
    "Moderate rain"* | "Moderate or heavy rain shower"* | "Rain")
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМе" || icon="юМИ"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМд" || icon="юМЗ"
        fi
        ;;
    "Patchy moderate snow"* | "Moderate snow"* | "Patchy heavy snow"* | "Heavy snow"* | "Moderate or heavy snow showers"*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМз" || icon="юМК"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юНб" || icon="юНЯ"
        fi
        ;;
    "Ice pellets"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 21 ] && icon="юМб" || icon="юМД"
        ;;
    *)
        s=72
        icon="юН┤"
        ;;
    esac
else
    s=72
    icon='яЬБ'
fi

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "$s" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

pgrep dunst >/dev/null && killall -q dunst
[ ! "$w" ] && unset r
if [ ! "$r" ]; then
    dunst -shrink -alignment "center" &
else
    dunst -geometry "410x3-4+4" -alignment "center" &
fi
d=$(date +"%A %d %B")
i=$(shuf -i 1-10000 -n 1)
z=0
c=8
until [ "$z" = "$c" ]; do
    dunstify -r "$i" -t 6000 -a 'fancy' "$(date +'%H:%M:%S')" "\n$d" \
        -i /tmp/dunst_icon.png
    sleep 0.5
    z=$((${z} + 1))
done
if [ -n "$r" ]; then
    dunstify -r "$i" -t 6000 -a 'fancy' "$t┬░C" "\n$w" \
        -i /tmp/dunst_icon.png
    sleep 3
    dunstify -r "$i" -t 6000 -a 'fancy' "$ws mph" "\n$wd" \
        -i /tmp/dunst_icon.png
    sleep 3
fi
dunstify -C "$i"
killall -q dunst
