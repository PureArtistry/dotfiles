#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)

nc -z -w 1 8.8.8.8 53 >/dev/null 2>&1
net=$?
if [ "$net" -eq 0 ]; then
    r=$(curl wttr.in/\?format=j1)
    w=$(echo "$r" | jq -r '.current_condition[0].weatherDesc[0].value')
    t=$(echo "$r" | jq -r '.current_condition[0].temp_C')
    ws=$(echo "$r" | jq -r '.current_condition[0].windspeedMiles')
    dn=$(date +"%H")

    if [ "$ws" -le 1 ]; then
        wd='Calm'
    elif [ "$ws" -gt 1 ] && [ "$ws" -le 3 ]; then
        wd='Light air'
    elif [ "$ws" -gt 3 ] && [ "$ws" -le 7 ]; then
        wd='Light breeze'
    elif [ "$ws" -gt 7 ] && [ "$ws" -le 12 ]; then
        wd='Gentle breeze'
    elif [ "$ws" -gt 12 ] && [ "$ws" -le 18 ]; then
        wd='Moderate breeze'
    elif [ "$ws" -gt 18 ] && [ "$ws" -le 24 ]; then
        wd='Fresh breeze'
    elif [ "$ws" -gt 24 ] && [ "$ws" -le 31 ]; then
        wd='Strong winds'
    elif [ "$ws" -gt 31 ]; then
        wd='Fuck THAT!'
    fi

    case "$w" in
    Clear*)
        s=58
        if [ "$ws" -lt 20 ]; then
            if [ "$dn" -le 5 ] || [ "$dn" -ge 20 ]; then
                icon="´¬ô"
                s=72
            else
                icon="ţîŹ"
            fi
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="´¬ť" || icon="ţŹŻ"
        fi
        ;;
    Sunny*)
        s=48
        if [ "$ws" -lt 20 ]; then
            if [ "$dn" -le 5 ] || [ "$dn" -ge 20 ]; then
                icon="ţŹŹ"
            else
                s=56
                icon="ţîŹ"
            fi
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="´¬ť" || icon="ţŹŻ"
        fi
        ;;
    "Partly cloudy"*)
        s=72
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţŹ╣" || icon="´¬ö"
        else
            s=48
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîč" || icon="ţîÇ"
        fi
        ;;
    Cloudy*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţŹż" || icon="ţîé"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîá" || icon="ţîü"
        fi
        ;;
    Overcast*)
        s=52
        if [ "$ws" -lt 20 ]; then
            if [ "$dn" -le 5 ] || [ "$dn" -ge 20 ]; then
                s=56
                icon="ţî«"
            else
                icon="ţîé"
            fi
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîč" || icon="ţîÇ"
        fi
        ;;
    Mist* | Fog* | "Freezing fog"* | "Shallow fog"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţŹć" || icon="ţîâ"
        ;;
    "Moderate or heavy rain with thunder"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţî¬" || icon="ţîĆ"
        ;;
    "Patchy light snow with thunder"* | "Moderate or heavy snow with thunder"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţŹž" || icon="ţŹą"
        ;;
    "Patchy light rain with thunder"* | "Thundery outbreaks possible"* | "Thunderstorm in vicinity"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîó" || icon="ţîů"
        ;;
    "Patchy rain possible"* | "Patchy light rain"* | "Light rain"* | "Shower in vicinity"* | "Rain shower"*)
        s=54
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîĘ" || icon="ţîő"
        ;;
    "Patchy snow possible"* | "Blowing snow"* | "Light snow"* | "Patchy light snow"*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîž" || icon="ţîŐ"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţŹí" || icon="ţŹč"
        fi
        ;;
    "Patchy sleet possible"* | "Light sleet"* | "Moderate or heavy sleet"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţÄČ" || icon="ţÄ¬"
        ;;
    "Patchy freezing drizzle possible"* | "Freezing drizzle"* | "Light freezing rain"*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîŽ" || icon="ţîć"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîĄ" || icon="ţîç"
        fi
        ;;
    Blizzard*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="´őť" || icon="´őť"
        ;;
    "Patchy light drizzle"* | "Light drizzle"* | "Drizzle"*)
        s=52
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţî┤" || icon="ţîë"
        ;;
    "Heavy freezing drizzle"* | "Heavy rain"* | "Moderate or heavy freezing rain"* | "Torrential rain shower"*)
        s=72
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="´¬Ľ" || icon="´¬Ľ"
        ;;
    "Moderate rain"* | "Moderate or heavy rain shower"* | "Rain")
        s=54
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîą" || icon="ţîł"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîĄ" || icon="ţîç"
        fi
        ;;
    "Patchy moderate snow"* | "Moderate snow"* | "Patchy heavy snow"* | "Heavy snow"* | "Moderate or heavy snow showers"*)
        s=48
        if [ "$ws" -lt 20 ]; then
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîž" || icon="ţîŐ"
        else
            [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţŹí" || icon="ţŹč"
        fi
        ;;
    "Ice pellets"*)
        s=48
        [ "$dn" -le 5 ] || [ "$dn" -ge 20 ] && icon="ţîí" || icon="ţîä"
        ;;
    *)
        s=72
        icon="ţŹ┤"
        ;;
    esac
else
    s=72
    icon='´ťü'
fi

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "$s" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

pgrep dunst >/dev/null && killall -q dunst
[ ! "$w" ] && unset r
if [ ! "$r" ]; then
    dunst -shrink -alignment "center" &
else
    dunst -geometry "410x3-4+4" -alignment "center" &
fi
d=$(date +"%A %d %B")
i=$(shuf -i 1-10000 -n 1)
z=0
c=8
until [ "$z" = "$c" ]; do
    dunstify -r "$i" -t 6000 -a 'fancy1' "$(date +'%H:%M:%S')" "$d" \
        -i /tmp/dunst_icon.png
    sleep 0.5
    z=$((${z} + 1))
done
if [ -n "$r" ]; then
    dunstify -r "$i" -t 6000 -a 'fancy1' "$t┬░C" "$w" \
        -i /tmp/dunst_icon.png
    sleep 3
    dunstify -r "$i" -t 6000 -a 'fancy1' "$ws mph" "$wd" \
        -i /tmp/dunst_icon.png
    sleep 3
fi
dunstify -C "$i"
killall -q dunst
