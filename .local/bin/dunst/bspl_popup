#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "60" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "" \
    /tmp/dunst_icon.png >/dev/null 2>&1

layout=$(bsp-layout get $(bspc query -T -d | jq -r '.name'))
i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment 'center' &
dunstify -r "$i" -t 6000 -a 'fancy1' "$layout" "current workspace layout" \
    -i /tmp/dunst_icon.png
sleep 4
dunstify -C "$i"
killall -q dunst
