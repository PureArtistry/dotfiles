#!/bin/sh

get_unit() {
    if [ "$1" -lt 2000 ]; then
        output="$1"
        su='b'
        ups='bps'
        [ "$output" -eq 1 ] && unit='byte' || unit='bytes'
    elif [ "$1" -ge 2000 ] && [ "$1" -lt 1200000 ]; then
        output=$((${1} / 1000))
        su='Kb'
        ups='Kbps'
        [ "$output" -eq 1 ] && unit='kilobyte' || unit='kilobytes'
    elif [ "$1" -ge 1200000 ] && [ "$1" -lt 1200000000 ]; then
        output=$((${1} / 1000000))
        su='Mb'
        ups='Mbps'
        [ "$output" -eq 1 ] && unit='megabyte' || unit='megabytes'
    elif [ "$1" -ge 1200000000 ]; then
        output=$((${1} / 1000000000))
        su='Gb'
        ups='Gbps'
        [ "$output" -eq 1 ] && unit='gigabyte' || unit='gigabytes'
    fi
    return
}

if [ -n "$1" ]; then
    td=$(ip route | grep default | awk '{print $5}')
    ti=$(cat /proc/net/dev | grep "$td")
    get_unit $(echo "$ti" | awk '{print $2}')
    tdl="ď€™  $output$su"
    get_unit $(echo "$ti" | awk '{print $10}')
    tul="ď‚“  $output$su"
    case "$td" in
    enp*) echo "ďś€  ethernet | $tdl | $tul" ;;
    wlp*)
        tid=$(nmcli connection show --active | grep 'wlp' | awk '{print $1}')
        echo "ď‚ž  $tid | $tdl | $tul"
        ;;
    esac
    exit
fi

calc() {
    crnt=$(cat /proc/net/dev | grep "$d")
    crx=$(echo "$crnt" | awk '{print $2}')
    ctx=$(echo "$crnt" | awk '{print $10}')
    [ "$n" -eq 0 ] && sum=$((${crx} - ${brx})) || sum=$((${ctx} - ${btx}))
    get_unit "$sum"
    [ "$output" -eq 0 ] && msg1='îŤ´' || msg1="$output $ups"
    [ "$n" -eq 0 ] && get_unit "$crx" || get_unit "$ctx"
    msg2="total: $output $unit"
    base="$crnt"
    brx="$crx"
    btx="$ctx"
    return
}

bye() {
    dunstify -C "$i"
    killall -q dunst
    exit
}

make_icon() {
    convert -size 90x90 xc:"$b" \
        -gravity center \
        -pointsize "$3" \
        -font "Iosevka-Nerd-Font-Complete" \
        -fill "$f" \
        -bordercolor "$bd" \
        -border '5' \
        -annotate +0+0 "$1" \
        /tmp/"$2".png >/dev/null 2>&1
    return
}

c=$(nmcli networking connectivity)
cl=$(nmcli connection show --active)
x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf)
b=$(echo "$x" | awk 'NR==20{print $2}')
f=$(echo "$x" | awk 'NR==2{print $2}')
bd=$(echo "$x" | awk 'NR==18{print $2}')

if [ "$c" != 'full' ]; then
    make_icon 'ď›·' 'dunst_icon' '72'
    msg1='no internet!'
    msg2='this is a problem'
else
    d=$(ip route | grep default | awk '{print $5}')
    case "$d" in
    enp*)
        make_icon 'ďś€' 'dunst_icon' '72'
        msg1='connected!'
        msg2='via ethernet'
        ;;
    wlp*)
        cid=$(echo "$cl" | grep 'wlp' | awk '{print $1}')
        make_icon 'ď‚ž' 'dunst_icon' '68'
        msg1='connected!'
        msg2="via $cid"
        ;;
    esac
fi

pgrep dunst >/dev/null && killall -q dunst
i=$(shuf -i 1-10000 -n 1)
dunst -geometry "420x3-4+4" -alignment "center" &
dunstify -r "$i" -t 6000 -a 'fancy1' "$msg1" "$msg2" -i /tmp/dunst_icon.png
if [ ! "$d" ]; then
    sleep 4
    bye
else
    sleep 3
    make_icon 'ď€™' 'dunst_icon0' '58'
    make_icon 'ď‚“' 'dunst_icon1' '58'
    base=$(cat /proc/net/dev | grep "$d")
    brx=$(echo "$base" | awk '{print $2}')
    btx=$(echo "$base" | awk '{print $10}')
    sleep 1
    n=0
    until [ "$n" -eq 2 ]; do
        j=0
        until [ "$j" -gt 3 ]; do
            calc
            dunstify -r "$i" -t 6000 -a 'fancy1' "$msg1" "$msg2" -i /tmp/dunst_icon"$n".png
            sleep 1
            j=$((${j} + 1))
        done
        n=$((${n} + 1))
    done
    bye
fi
