#!/bin/sh

neocover > /dev/null 2>&1

# tweak some configs post generation

global_bg=$(sed -n 1p "$XDG_CACHE_HOME"/wal/colors)
sxiv_foreground=$(sed -n 2p "$XDG_CACHE_HOME"/wal/colors)
sed -i "1s/.*/*background: $global_bg/g" $HOME/.Xresources
sed -i "2s/.*/*foreground: $sxiv_foreground/g" $HOME/.Xresources
xrdb -merge $HOME/.Xresources

ripcord_check=$(pidof ripcord)
[ ! $ripcord_check ] && sed -i '/preset_name=custom/d' $XDG_DATA_HOME/Ripcord/settings.ini

# force apps to use new theme, except on startup to prevent doubling up

[ -f /tmp/startup.tmp ] && exit

if [ -n "$ripcord_check" ]; then
	kill $ripcord_check
	while kill -0 $ripcord_check 2> /dev/null; do sleep 0.1; done
	sed -i '/preset_name=custom/d' $XDG_DATA_HOME/Ripcord/settings.ini
	restart_ripcord=yes
fi

pgrep fancy_writing > /dev/null && pkill fancy_writing --signal=USR1
pgrep qutebrowser > /dev/null && qutebrowser :config-source :reload > /dev/null 2>&1
reinit_desktop
pkill zsh --signal=USR1
[ $restart_ripcord = "yes" ] && sleep 0.2 && ripcord &
follow=$(head -n1 /tmp/breadcrumbs)
[ ! $follow ] && bspc desktop 1 -f || bspc desktop $(head -n1 /tmp/breadcrumbs) -f
home_desktop=$(bspc query -d focused -T | jq '.name')
[ $home_desktop = '"1"' ] && feng_shui
