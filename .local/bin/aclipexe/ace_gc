#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)

make_icon() {
    convert -size 90x90 xc:"$b" \
        -gravity center \
        -pointsize "60" \
        -font "Iosevka-Nerd-Font-Complete" \
        -fill "$f" \
        -bordercolor "$bd" \
        -border '5' \
        -annotate +0+0 "" \
        /tmp/dunst_icon.png >/dev/null 2>&1
    return
}

make_icon
i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -geometry "380x3-4+4" -alignment 'center' &
repo=$(echo "$1" | awk -F '/' '{print $NF}' | sed 's/\.git//')
dunstify -r "$i" -t 4000 -a 'fancy1' "$repo" "cloning to ~/downloads/git" -i /tmp/dunst_icon.png
cd $HOME/downloads/git
git clone "$1"
make_icon
dunstify -r "$i" -t 6000 -a 'fancy1' "ready!" "~/downloads/git/$repo" -i /tmp/dunst_icon.png
sleep 4
dunstify -C "$i"
killall -q dunst
