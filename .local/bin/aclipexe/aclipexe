processed=""

main() {
    while clipnotify; do
        selection=$(xclip -selection clipboard -o)
        [ ! "$selection" ] || [ "$selection" = "$processed" ] && main
        case "$selection" in
        https://*.*/*.png | https://*.*/*.jpg | https://*.*/*.jpeg) image_bit ;;
        https://*.youtube.com/watch* | https://*.youtu.be/watch*) youtube ;;
        magnet:?* | *magnet*tracker*) torrent ;;
        https://*twitch.tv/*) twitch ;;
        https://*.redd*/*) reddit ;;
        https://*.*/*.git) gitbit ;;
        *) ignore ;;
        esac
    done
}

new_face_in_town() {
    pgrep dunst >/dev/null && killall -q dunst
    dunst -shrink -alignment "center" &
    return
}

and_the_horse_you_rode_in_on() {
    dunstify -C 010101
    killall -q dunst
    [ "$1" = passthrough ] && main || return
}

make_icon() {
    x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
    b=$(echo "$x" | sed -n 20p)
    f=$(echo "$x" | sed -n 2p)
    bd=$(echo "$x" | sed -n 18p)

    convert -size 90x90 xc:"$b" \
        -gravity center \
        -pointsize "$1" \
        -font "Iosevka-Nerd-Font-Complete" \
        -fill "$f" \
        -bordercolor "$bd" \
        -border '5' \
        -annotate +0+0 "$2" \
        /tmp/dunst_icon.png >/dev/null 2>&1
    return
}

listening() {
    need_mute=$(mpc current)
    [ -n "$need_mute" ] && paused=$(mpc | sed -n 2p \
        | awk '{print $1}' | grep "paused")
    [ -n "$need_mute" ] && [ ! "$paused" ] && need_mute=yes
    return
}

youtube() {
    processed="$selection"
    rofeo aclipexe "$(echo $selection | sed 's/\&.*//' | awk -F '=' '{print $NF}')"
    main
}

twitch() {
    processed="$selection"
    local msg=$(echo "$selection" | wc -c)
    [ "$msg" -ge 43 ] && msg=$(echo "$selection" | cut -c 1-40 | sed 's/$/.../') \
        || msg="$selection"
    bar=$($utter "  fullscreen\n  home screen\n  interactive" | rofi -theme 'video1' \
        -p "  viewing experience?" \
        -mesg "  $msg" \
        -lines 3 -fixed-num-lines 3 -dmenu -i -format d)
    [ ! "$bar" ] && main
    local name=$(echo "$selection" | awk -F '/' '{print $NF}')
    case "$bar" in
    1)
        listening
        make_icon '64' ''
        new_face_in_town
        dunstify -r 010101 -t 10000 -a 'fancy1' "loading" "$name" \
            -i /tmp/dunst_icon.png
        bspc rule -a mpv:\* -o desktop=10 state=fullscreen
        streamlink -p mpv "$selection" best &
        bspc subscribe node_add -c 1
        and_the_horse_you_rode_in_on
        [ "$need_mute" = "yes" ] && mpc pause
        bspc desktop 10 -f
        ;;
    2)
        listening
        make_icon '64' ''
        new_face_in_town
        dunstify -r 010101 -t 10000 -a 'fancy1' "loading" "$name" \
            -i /tmp/dunst_icon.png
        distraction_toggle off
        bspc rule -a mpv:\* -o desktop=1 state=floating \
            rectangle=897x505+1005+287 center=false
        streamlink -p mpv "$selection" best &
        bspc subscribe node_add -c 1
        and_the_horse_you_rode_in_on
        [ "$need_mute" = "yes" ] && mpc pause
        bspc desktop 1 -f
        sleep 0.1
        xdotool mousemove 400 400
        bspc node pointed -f
        ;;
    3)
        listening
        make_icon '64' ''
        new_face_in_town
        dunstify -r 010101 -t 10000 -a 'fancy1' "loading" "$name" \
            -i /tmp/dunst_icon.png
        bspc rule -a mpv:\* -o desktop=10 state=tiled
        streamlink -p mpv "$selection" best &
        bspc subscribe node_add -c 1
        and_the_horse_you_rode_in_on
        [ "$need_mute" = "yes" ] && mpc pause
        bspc desktop 10 -f
        bspc node -p east
        bspc node -o 0.74
        chat=$($utter "$selection" | awk -F "/" '{print $4}')
        qutebrowser --target window \
            https://www.twitch.tv/popout/"$chat"/chat?popout= &
        ;;
    esac
    xclip -selection clipboard /dev/null
    main
}

torrent() {
    processed="$selection"
    transmission-remote -a "$selection"
    make_icon '60' ''
    new_face_in_town
    dunstify -t 4000 -a 'fancy1' "added" "to transmission queue" -i /tmp/dunst_icon.png
    xclip -selection clipboard /dev/null
    main
}

reddit() {
    processed="$selection"
    xdg-open "$selection"
    xclip -selection clipboard /dev/null
    main
}

gitbit() {
    processed="$selection"
    ace_gc "$selection" &
    xclip -selection clipboard /dev/null
    main
}

image_bit() {
    processed="$selection"
    og_name=$(echo "$selection" | awk -F '/' '{print $NF}')
    ext=$(echo "$selection" | awk -F '.' '{print $NF}')
    temp_name="$(date +'%s').img.$ext"
    wp_total=$(ls -1 $HOME/images/wallpapers | wc -l)
    wget -q -O /tmp/"$temp_name" "$selection"
    convert /tmp/"$temp_name" -resize 460x259^ \
        -gravity center -extent 460x259 \
        -flatten /tmp/rofi_thumb.png
    bspc rule -a Sxiv:\* -o state=floating manage=off
    sxiv -g 460x259+730+268 -p -b /tmp/rofi_thumb.png &
    thumb_pid="$!"
    img_option=$(echo "  download image\n  set as wallpaper\n  open in gimp" \
        | rofi -theme 'image' -dmenu \
            -p "  $og_name" \
            -mesg "  you currently have $wp_total wallpapers" \
            -lines 3 -fixed-num-lines 3 -format d)
    xclip -selection clipboard /dev/null
    if [ ! "$img_option" ]; then
        kill "$thumb_pid"
        main
    fi
    case "$img_option" in
    1)
        new_name=$(rofi -theme 'entry' -dmenu -i -mesg '凜 are you naming this?')
        kill "$thumb_pid"
        [ ! "$new_name" ] && tn="$og_name" || tn="$new_name.$ext"
        cp /tmp/"$temp_name" "$HOME"/images/download/"$tn"
        make_icon '66' ''
        new_face_in_town
        dunstify -r 010101 -t 4000 -a 'fancy1' "copied" "$tn" -i /tmp/dunst_icon.png
        ;;
    2)
        new_name=$(rofi -theme 'entry' -dmenu -i -mesg '凜 are you naming this?')
        kill "$thumb_pid"
        [ ! "$new_name" ] && tn="$og_name" || tn="$new_name.$ext"
        cp /tmp/"$temp_name" "$HOME"/images/wallpapers/"$tn"
        wpg -a "$HOME"/images/wallpapers/"$tn"
        theme_change "$tn" &
        ;;
    3)
        kill "$thumb_pid"
        gimp /tmp/"$temp_name" &
        ;;
    esac
    main
}

ignore() {
    processed="$selection"
    main
}

main
