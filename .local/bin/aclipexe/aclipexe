#!/bin/sh

# (a)utomatic (clip)board (exe)cution

processed=""

main(){
	while clipnotify; do
		selection=$(xclip -selection clipboard -o)
		[ ! "$selection" ] || [ "$selection" = "$processed" ] && main
		case "$selection" in
			https://*.youtube.com/watch*) youtube ;;
			https://*.youtu.be/watch*) youtube ;;
			*magnet*tracker*) torrent ;;
			magnet:?*) torrent ;;
			https://*twitch.tv/*) twitch ;;
			https://*.redd*/*) reddit ;;
			*) ignore ;;
		esac
	done
}

new_face_in_town(){
	killall -q dunst
	dunst -config $XDG_CONFIG_HOME/dunst/dunst.mini &
	return
}

and_the_horse_you_rode_in_on(){
	dunstify -C 010101
	killall -q dunst
	[ $1 = passthrough ] && cleanup || return
}

cleanup(){
	[ -d $HOME/.w3m ] && rm -rf $HOME/.w3m
	[ -d $HOME/.nv ] && rm -rf $HOME/.nv
	[ -f $HOME/.fehbg ] && rm -f $HOME/.fehbg
	main
}

youtube(){
	processed="$selection"
	new_face_in_town
	dunstify -r 010101 -t 6000000 "viewing experience?"
	foo=$(echo "download\nfullscreen\nmusic video\nstandard" \
		| rofi -dmenu -i -format d)
	[ ! $foo ] && and_the_horse_you_rode_in_on passthrough || and_the_horse_you_rode_in_on
	case $foo in
		1) youtube-dl "$selection" &
			dunstify -r 3001 -t 3000 "downloading" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/ytdl_sml.png ;;
		2) listening
			dunstify -r 3001 -t 3000 "loading video" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/ytdl_sml.png
			bspc rule -a mpv:\* -o desktop=10
			mpv "$selection" --fs &
			bspc subscribe node_add -c 1
			[ "$need_mute" = "yes" ] && mpc pause
			bspc desktop 10 -f ;;
		3) listening
			dunstify -r 3001 -t 3000 "loading video" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/ytdl_sml.png
			distraction_toggle off
			bspc rule -a mpv:\* -o desktop=1 state=floating \
				rectangle=897x505+1005+287 center=false
			mpv "$selection" &
			bspc subscribe node_add -c 1
			[ "$need_mute" = "yes" ] && mpc pause
			bspc desktop 1 -f
			sleep 0.1
			xdotool mousemove 400 400
			bspc node pointed -f ;;
		4) listening
			dunstify -r 3001 -t 3000 "loading video" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/ytdl_sml.png
			mpv "$selection" &
			bspc subscribe node_add -c 1
			[ "$need_mute" = "yes" ] && mpc pause ;;
	esac
	xclip -selection clipboard /dev/null
	cleanup
}

listening(){
	need_mute=$(mpc current)
	[ -n "$need_mute" ] && paused=$(mpc | sed -n 2p \
		| awk '{print $1}' | grep "paused")
	[ -n "$need_mute" ] && [ ! "$paused" ] && need_mute=yes
	return
}

torrent(){
	processed=$selection
	transmission-remote -a "$selection"
	dunstify -t 3000 "torrent added" \
		-i $XDG_CONFIG_HOME/dunst/icons/transmission.svg
	xclip -selection clipboard /dev/null
	cleanup
}

twitch(){
	processed=$selection
	new_face_in_town
	dunstify -r 010101 -t 6000000 "viewing experience?"
	bar=$(echo "interactive\ndistraction\nfullscreen" | rofi -dmenu -i -format d)
	[ ! $bar ] && and_the_horse_you_rode_in_on passthrough || and_the_horse_you_rode_in_on
	case $bar in
		1) listening
			dunstify -t 3000 "loading stream" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/twitch.svg
			bspc rule -a mpv:\* -o desktop=10 state=tiled
			streamlink -p mpv "$selection" best &
			bspc subscribe node_add -c 1
			[ "$need_mute" = "yes" ] && mpc pause
			bspc desktop 10 -f
			bspc node -p east
			bspc node -o 0.74
			chat=$(echo "$selection" | awk -F "/" '{print $4}')
			qutebrowser --target window \
				https://www.twitch.tv/popout/"$chat"/chat?popout= & ;;
		2) listening
			dunstify -t 3000 "loading stream" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/twitch.svg
			distraction_toggle off
			bspc rule -a mpv:\* -o desktop=1 state=floating \
				rectangle=897x505+1005+287 center=false
			streamlink -p mpv "$selection" best &
			bspc subscribe node_add -c 1
			[ "$need_mute" = "yes" ] && mpc pause
			bspc desktop 1 -f
			sleep 0.1
			xdotool mousemove 400 400
			bspc node pointed -f ;;
		3) listening
			dunstify -t 3000 "loading stream" "$selection" \
				-i $XDG_CONFIG_HOME/dunst/icons/twitch.svg
			bspc rule -a mpv:\* -o desktop=10 state=fullscreen
			streamlink -p mpv "$selection" best &
			bspc subscribe node_add -c 1
			[ "$need_mute" = "yes" ] && mpc pause
			bspc desktop 10 -f ;;
	esac
	xclip -selection clipboard /dev/null
	cleanup
}

reddit(){
	processed=$selection
	xdg-open "$selection"
	xclip -selection clipboard /dev/null
	cleanup
}

ignore(){
	processed=$selection
	cleanup
}

main
