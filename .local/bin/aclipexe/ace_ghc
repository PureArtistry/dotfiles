#!/bin/sh

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)

convert -size 75x75 xc:"$b" \
    -gravity center \
    -pointsize "52" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "" \
    /tmp/dunst_icon.png >/dev/null 2>&1

i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment 'center' &
repo=$(echo "$1" | awk -F '/' '{print $NF}' | sed 's/\.git//')
dunstify -r "$i" -t 3000 -a 'fancy' "$repo" "\ncloning repo..." -i /tmp/dunst_icon.png
cd $HOME/downloads/git
git clone "$1"
dunstify -r "$i" -t 6000 -a 'fancy' "finished" "\ncloning $repo" -i /tmp/dunst_icon.png
sleep 4
dunstify -C "$i"
killall -q dunst
