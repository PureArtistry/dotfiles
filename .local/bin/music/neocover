#!/bin/sh

# album art grabber (originally for neofetch)

[ -f /tmp/startup.tmp ] && exit
music_directory=$HOME/music
now_playing=$(mpc -f %file% current)
up_next=$(mpc -f %file% queued)

rm /tmp/neocover.png
rm /tmp/dartc.png
rm /tmp/dartn.png

art_check() {
    path=$(ls -1 "$1")
    case $path in
    *cover.jpg) cp "$1"/cover.jpg /tmp/$2 && return ;;
    *cover.jpeg) cp "$1"/cover.jpeg /tmp/$2 && return ;;
    *cover.png) cp "$1"/cover.png /tmp/$2 && return ;;
    *)
        ffmpeg -i "$music_directory/$3" /tmp/$2 >/dev/null 2>&1
        x=$(echo "$1" | grep -e 'Non-Album' -e 'TBS/songs')
        [ ! "$x" ] && cp /tmp/"$2" "$1"/cover.png >/dev/null 2>&1
        ;;
    esac
    return
}

copy_new() {
    if [ ! "$now_playing" ]; then
        [ -f /tmp/dartc.png ] || cp $XDG_CONFIG_HOME/wpg/.current /tmp/neocover.png
    else
        [ -f /tmp/dartc.png ] || cp $ARTISTRY/no_art.png /tmp/neocover.png
    fi
    [ -f /tmp/neocover.png ] || cp /tmp/dartc.png /tmp/neocover.png
    [ -f /tmp/dartc.png ] || cp $ARTISTRY/no_art.png /tmp/dartc.png
    [ -f /tmp/dartn.png ] || cp $ARTISTRY/no_art.png /tmp/dartn.png
    return
}

make_square() {
    if [ "$1" = "neocover.png" ]; then
        convert /tmp/"$1" -resize 500x500^ \
            -gravity center -extent 500x500 \
            -flatten /tmp/albumart.png
    else
        convert /tmp/"$1" -resize 500x500^ \
            -gravity center -extent 500x500 \
            -bordercolor "$(awk 'NR==18{print $2}' $XDG_CONFIG_HOME/kitty/kitty_colors.conf)" \
            -border 5 \
            -flatten /tmp/"$1"
    fi
    return
}

foo=${now_playing%/*}
bar=${up_next%/*}
[ ! "$foo" ] || art_check $music_directory/"$foo" dartc.png "$now_playing"
art_check $music_directory/"$bar" dartn.png "$up_next"
copy_new
make_square neocover.png
make_square dartc.png
make_square dartn.png
