#!/bin/sh

# hacky rofi based youtube search

this_is_getting_silly(){
	dunstify -C 929293
	killall -q dunst
	[ $1 = "bleh" ] && exit || return
}

search=$(rofi -dmenu -i -p "‎‎  youtube: " -no-fixed-num-lines -format s \
	-config $XDG_CONFIG_HOME/rofi/config-mini.rasi | sed  s'/ /+/g')
[ ! $search ] && exit
list=$(curl https://www.youtube.com/results?search_query="${search}")

killall -q dunst
dunst -config $XDG_CONFIG_HOME/dunst/dunst.mini &

dunstify -r 929293 -t 6000000 "find what you're looking for?"
choice=$(echo "$list" | grep -Po '(?<=title=")(.*?)(?=" rel="spf)' | \
	sed  s"/&#39;/'/g" | sed s'/&quot;/"/g' | \
	rofi -dmenu -i -format d)
[ ! $choice ] && this_is_getting_silly bleh || this_is_getting_silly
watch=$(echo "$list" | grep -Po '(?<=a href="/watch\?v=)(.*?)(?=" class)' | sed -n ${choice}p)
echo -n https://www.youtube.com/watch?v="${watch}" | xclip -selection clipboard
