#!/bin/sh
SHELL_TYPE=$(readlink /bin/sh)
case "$SHELL_TYPE" in
*dash) utter='echo' ;;
*) utter='echo -e' ;;
esac

# exit menu using rofi

my_uptime=$(uptime -p | awk '{print $2, $3, $4, $5}')
case "$my_uptime" in
*,) my_uptime=$(echo "> $my_uptime" | sed 's/.$//') ;;
esac

foo=$($utter '’£ģ logout \n’ĆŻ secure \nŌĆÄ’░ćŌĆÄ reboot ' | rofi -theme 'exit' -no-cycle -dmenu -i \
    -mesg "’Ćć  $(echo "$USER") | ’äē   $(head -n1 /etc/hostname) | ’Öæ  $my_uptime" \
    -p 'going somewhere..?' -selected-row 1 -format d)
[ ! $foo ] && exit
case $foo in
1)
    pgrep qutebrowser >/dev/null 2>&1 && qutebrowser :quit >/dev/null 2>&1
    bspc quit
    ;;
2) exit ;;
3)
    pgrep qutebrowser >/dev/null 2>&1 && qutebrowser :quit >/dev/null 2>&1
    systemctl reboot
    ;;
esac
