#!/bin/sh

# that tune? rinsed it!

you_too(){
	dunstify -C 202020
	killall -q dunst
	exit
}

killall -q dunst
dunst -config $XDG_CONFIG_HOME/dunst/dunst.mini &
now_playing=$(mpc | sed -n 2p | awk '{print $1}')
case $now_playing in
	*paused*) paused=$(mpc current)
		dunstify -r 202020 -t 600000 "’üī  $paused" ;;
	*) up_next=$(mpc queued)
		dunstify -r 202020 -t 600000 "’üÉ  $up_next" ;;
esac
song_selection=$(mpc playlist | rofi -dmenu -i -format d)
[ ! "$song_selection" ]	&& you_too
mpc -q play $song_selection
you_too
