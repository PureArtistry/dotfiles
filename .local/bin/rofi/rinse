#!/bin/sh

# that tune? rinsed it!

stats=$(mpc stats)
x=$(echo "$stats" | head -n1 | awk '{print $2}')
y=$(echo "$stats" | sed -n 2p | awk '{print $2}')
z=$(echo "$stats" | sed -n 3p | awk '{print $2}')
t=$(echo "$stats" | tail -n1 | awk '{for (i=4; i <= NF; i++) printf $i""FS; print""}')
playing=$(mpc current -f '%position%')
[ ! "$playing" ] && playing=0 || playing=$((${playing} - 1))
up_next=$(mpc queued -f '%title%')
[ $(echo "$up_next" | wc -c) -gt 29 ] && up_next=$(echo "$up_next" | cut -c 1-26 | sed 's/$/.../')
song_selection=$(mpc playlist | rofi -theme 'rinse' -keep-right \
    -mesg "яжм $up_next" \
    -p " тАОя┤БтАО  $x | тАОяФдтАО  $y | тАОяАБтАО  $z | яиЩ  $t" \
    -selected-row "$playing" -u "$playing" -no-custom -dmenu -i -format d)
[ ! "$song_selection" ] && exit
mpc -q play "$song_selection"
