#!/bin/sh

# quick & dirty game launcher

the_usual(){
	dunstify -C 881166
	killall -q dunst
	[ $1 = "everything" ] && exit || return
}

games=$(lutris -l)
killall -q dunst
dunst -config $XDG_CONFIG_HOME/dunst/dunst.mini &
dunstify -r 881166 -t 600000 "Jack is not dull!"
choice=$(echo "$games" | sort | awk -F "|" '{print $2}' | sed 's/[[:blank:]]*$//' | rofi -dmenu -i -format d)
[ ! $choice ] && the_usual everything || the_usual
distraction_toggle off
bspc desktop 9 -f
lutris lutris:rungameid/"$choice" &
