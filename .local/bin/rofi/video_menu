#!/bin/sh
SHELL_TYPE=$(readlink /bin/sh)
case $SHELL_TYPE in
*dash) utter='echo' ;;
*) utter='echo -e' ;;
esac

# rofi menu for quickly playing videos

x=$(ls -1 $VIDEO)
catnum=$(echo "$x" | wc -l)
vid_total=$(find $VIDEO/ -type f | wc -l)
catagory=$(echo "$x" | rofi -theme 'video1' -lines "$catnum" -fixed-num-lines "$catnum" \
    -p "what do you fancy watching?" \
    -mesg "  $vid_total videos in total to select from..." \
    -selected-row "$((${catnum} - 1))" -dmenu -i -format s)
[ ! $catagory ] && exit

list=$(find $VIDEO/$catagory -type f -printf "%f|%h\n" | sort)
choice=$($utter "$list" | awk -F "|" '{print $1}' | rofi -theme 'video2' \
    -p "羽 just one more menu to go..." \
    -mesg "pick a title..." \
    -dmenu -i -format d)
[ ! $choice ] && exit
file=$($utter "$list" | awk -F "|" '{print $2"/"$1}' | sed -n ${choice}p)

duration=$(mediainfo "$file" | grep -m 1 'Duration' | awk -F ':' '{print $2}')
experience=$($utter "fullscreen\ndistraction\nstandard" | rofi -theme 'video1' \
    -p "viewing experience?" \
    -mesg "please enjoy the next$duration" \
    -lines 3 -fixed-num-lines 3 -dmenu -i -format d)
[ ! $experience ] && exit
need_mute=$(mpc current)
[ -n "$need_mute" ] && paused=$(mpc | sed -n 2p | awk '{print $1}' | grep "paused")
[ -n "$need_mute" ] && [ ! "$paused" ] && need_mute=yes
case $experience in
1)
    bspc rule -a mpv:\* -o desktop=10
    mpv "$file" --fs &
    bspc subscribe node_add -c 1
    bspc desktop 10 -f
    [ "$need_mute" = "yes" ] && mpc pause
    ;;
2)
    distraction_toggle off
    bspc rule -a mpv:\* -o desktop=1 state=floating rectangle=897x505+1005+287 center=false
    mpv "$file" &
    bspc subscribe node_add -c 1
    [ "$need_mute" = "yes" ] && mpc pause
    bspc desktop 1 -f
    sleep 0.1
    xdotool mousemove 400 400
    bspc node pointed -f
    ;;
3)
    mpv "$file" &
    bspc subscribe node_add -c 1
    [ "$need_mute" = "yes" ] && mpc pause
    ;;
esac
