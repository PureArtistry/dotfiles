#!/bin/sh

# script to display system/life/song information
# idea (sort of) inspired by https://github.com/sdushantha/fontpreview

catch_signal_usr1() {
    trap catch_signal_usr1 USR1
    state="update"
    break
}
trap catch_signal_usr1 USR1

main() {
    count=0
    cycle=0
    state="running"
    [ -f /tmp/fancy_message ] && other_info fancy_message
    now_playing=$(mpc | sed -n 2p | awk '{print $1}')
    [ ! "$now_playing" ] && other_info
    case "$now_playing" in
    *paused*) other_info pause ;;
    *) song_info ;;
    esac
}

other_info() {
    [ "$1" = "fancy_message" ] && general="$(head -n1 /tmp/fancy_message)" \
        || general="Hello Dave. You're looking well today."
    # general="‎שּ‎ ‎‎   hi reddit!"
    until [ "$state" = "update" ]; do
        if [ "$1" = "pause" ]; then
            song=$(mpc current -f "%title%")
            if [ "$count" = 100 ]; then
                count=0
                [ "$cycle" = 1 ] && cycle=0 || cycle=$((${cycle} + 1))
            fi
            if [ "$cycle" = 0 ]; then
                message="  $song"
                fancy_font="Iosevka-Nerd-Font-Complete"
                display_text
                loop
            elif [ "$cycle" = 1 ]; then
                message="$general"
                fancy_font="Victor-Mono-Medium-Italic-Nerd-Font-Complete"
                display_text
                loop
            fi
        else
            [ "$count" = 100 ] && count=0
            message="$general"
            [ "$1" = "fancy_message" ] \
                && fancy_font="Iosevka-Nerd-Font-Complete" \
                || fancy_font="Victor-Mono-Medium-Italic-Nerd-Font-Complete"
            display_text
            loop
        fi
    done
    main
}

song_info() {
    song=$(mpc current -f "%title%")
    artist=$(mpc current -f "%artist%")
    album=$(mpc current -f "%album%")
    date=$(mpc current -f "%date%")
    until [ "$state" = "update" ]; do
        if [ "$count" = 100 ]; then
            count=0
            [ "$cycle" = 3 ] && cycle=0 || cycle=$((${cycle} + 1))
        fi
        if [ "$cycle" = 0 ]; then
            [ ! "$song" ] && message="  missing IDv3 tags" || message="  $song"
            fancy_font="Iosevka-Nerd-Font-Complete"
            display_text
            loop
        elif [ "$cycle" = 1 ]; then
            [ ! "$artist" ] && message="  missing IDv3 tags" \
                || message="‎ﴁ‎  $artist"
            fancy_font="Iosevka-Nerd-Font-Complete"
            display_text
            loop
        elif [ "$cycle" = 2 ]; then
            [ ! "$album" ] && message="  missing IDv3 tags" || message="  $album"
            fancy_font="Iosevka-Nerd-Font-Complete"
            display_text
            loop
        elif [ "$cycle" = 3 ]; then
            [ ! "$date" ] && message="  missing IDv3 tags" \
                || message="‎ﮮ‎  $date"
            fancy_font="Iosevka-Nerd-Font-Complete"
            display_text
            loop
        fi
    done
    main
}

loop() {
    while [ "$count" -lt 100 ] && [ "$state" != "update" ]; do
        sleep 0.2
        count=$((${count} + 1))
    done
    return
}

display_text() {
    bspc node $(head -n 1 /tmp/fancy_writing_id) --flag hidden=on
    sleep 0.1
    clear
    fg_color=$(sed -n 8p $XDG_CACHE_HOME/wal/colors)
    length_check=$(echo -n "$message" | wc -c)
    [ "$length_check" -gt 39 ] && final_message=$(echo "$message" | cut -c 1-36 \
        | sed 's/$/.../g') || final_message="$message"
    [ "$fancy_font" = 'Victor-Mono-Medium-Italic-Nerd-Font-Complete' ] \
        && font_size=31 || font_size=34
    convert -size 650x200 xc:"transparent" \
        -gravity center \
        -pointsize "$font_size" \
        -font "$fancy_font" \
        -fill "$fg_color" \
        -annotate +0+65 "$final_message" \
        /tmp/fancy_writing.png >/dev/null 2>&1
    kitty +kitten icat /tmp/fancy_writing.png >/dev/null 2>&1
    sleep 0.1
    bspc node $(head -n 1 /tmp/fancy_writing_id) --flag hidden=off
    if [ -f /tmp/fancy_message ]; then
        rm -f /tmp/fancy_message
        loop
        main
    fi
    return
}

fancy_writing_id=$(xwininfo -root -children | grep -w "fancy writing" | awk '{print $1}')
echo "$fancy_writing_id" >/tmp/fancy_writing_id
main
