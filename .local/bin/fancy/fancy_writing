catch_signal_usr1() {
    trap catch_signal_usr1 USR1
    state="update"
    break
}
trap catch_signal_usr1 USR1

catch_signal_usr2() {
    trap catch_signal_usr2 USR2
    state="update"
    pm_run=1
    break
}
trap catch_signal_usr2 USR2

main() {
    count=0
    cycle=0
    state="running"
    now_playing=$(mpc | sed -n 2p | awk '{print $1}')
    [ ! "$now_playing" ] && other_info
    case "$now_playing" in
    *paused*) other_info pause ;;
    *) song_info ;;
    esac
}

update_check() {
    nc -z -w 1 8.8.8.8 53 >/dev/null 2>&1
    local net=$?
    if [ "$net" -eq 0 ]; then
        if [ -z "$uc_interval" ] || [ $(($(date +'%s') - ${uc_interval})) -gt 1800 ] || [ -n "$pm_run" ]; then
            uc_interval=$(date +'%s')
            [ -n "$pm_run" ] && unset pm_run
            local p=$(checkupdates 2>/dev/null | wc -l)
            local y=$(yay -Qum 2>/dev/null | wc -l)
            [ ! "$p" ] && p=0
            [ ! "$y" ] && y=0
            local t=$((${p} + ${y}))
            if [ "$t" = 1 ]; then
                update_status="’Æć  there's an update available"
            elif [ "$t" -gt 0 ]; then
                update_status="’Æć  you have $t updates waiting"
            else
                update_status="’ģż  your system is up to date"
            fi
        fi
    else
        update_status="’øĘ  there's no internet!"
    fi
    return
}

other_info() {
    [ ! "$wp_timer" ] && wp_timer=$(date +'%s')
    general="Hello Dave. You're looking well today."
    until [ "$state" = "update" ]; do
        if [ "$1" = "pause" ]; then
            song=$(mpc current -f "%title%")
            if [ "$count" = 100 ]; then
                count=0
                [ "$cycle" = 3 ] && cycle=0 || cycle=$((${cycle} + 1))
            fi
            if [ "$cycle" = 0 ]; then
                fancy_font='Iosevka-Nerd-Font-Complete'
                message="’üī  $song"
                display_text
                loop
            elif [ "$cycle" = 1 ]; then
                if [ -f /tmp/fancy_message ]; then
                    local x=$(cat /tmp/fancy_message)
                    message=$(echo "$x" | head -n1)
                    local font=$(echo "$x" | sed -n 2p)
                    case "$font" in
                    1) fancy_font='Victor-Mono-Medium-Italic-Nerd-Font-Complete' ;;
                    *) fancy_font='Iosevka-Nerd-Font-Complete' ;;
                    esac
                    rm -f /tmp/fancy_message 2>/dev/null
                else
                    message="$general"
                    fancy_font='Victor-Mono-Medium-Italic-Nerd-Font-Complete'
                fi
                display_text
                loop
            elif [ "$cycle" = 2 ]; then
                fancy_font='Iosevka-Nerd-Font-Complete'
                topjob=$(task 2>/dev/null | sed -n 4p)
                job_no=$(echo "$topjob" | awk '{print $1}')
                job_due=$(echo "$topjob" | awk '{print $5}')
                job_desc=$(task export 2>/dev/null | jq -r ".[$((${job_no} - 1))].description")
                [ $(echo "$job_desc" | wc -c) -gt 22 ] \
                    && job_desc=$(echo "$job_desc" | cut -c 1-19 | sed 's/$/.../')
                message="ŌĆÄ’¬┤ŌĆÄ  $job_desc ($job_due)"
                display_text
                loop
            elif [ "$cycle" = 3 ]; then
                update_check
                fancy_font='Iosevka-Nerd-Font-Complete'
                message="$update_status"
                display_text
                loop
            fi
        else
            if [ "$count" = 100 ]; then
                count=0
                [ "$cycle" = 2 ] && cycle=0 || cycle=$((${cycle} + 1))
            fi
            if [ "$cycle" = 0 ]; then
                if [ -f /tmp/fancy_message ]; then
                    local x=$(cat /tmp/fancy_message)
                    message=$(echo "$x" | head -n1)
                    local font=$(echo "$x" | sed -n 2p)
                    case "$font" in
                    1) fancy_font='Victor-Mono-Medium-Italic-Nerd-Font-Complete' ;;
                    *) fancy_font='Iosevka-Nerd-Font-Complete' ;;
                    esac
                    rm -f /tmp/fancy_message 2>/dev/null
                else
                    message="$general"
                    fancy_font='Victor-Mono-Medium-Italic-Nerd-Font-Complete'
                fi
                if [ $(($(date +'%s') - ${wp_timer})) -gt 180 ]; then
                    wp_timer=$(date +'%s')
                    wp_list=$(ls -1 $HOME/images/wallpapers)
                    rand_wall=$(shuf -i 1-$(echo "$wp_list" | wc -l) -n 1)
                    wallpaper=$(echo "$wp_list" | sed -n ${rand_wall}p)
                    wallpaper="${HOME}/images/wallpapers/${wallpaper}"
                    convert "$wallpaper" -resize 500x500^ \
                        -gravity center -extent 500x500 \
                        -flatten /tmp/albumart.png
                fi
                display_text
                loop
            elif [ "$cycle" = 1 ]; then
                fancy_font='Iosevka-Nerd-Font-Complete'
                topjob=$(task 2>/dev/null | sed -n 4p)
                job_no=$(echo "$topjob" | awk '{print $1}')
                job_due=$(echo "$topjob" | awk '{print $5}')
                job_desc=$(task export 2>/dev/null | jq -r ".[$((${job_no} - 1))].description")
                [ $(echo "$job_desc" | wc -c) -gt 22 ] \
                    && job_desc=$(echo "$job_desc" | cut -c 1-19 | sed 's/$/.../')
                message="ŌĆÄ’¬┤ŌĆÄ  $job_desc ($job_due)"
                display_text
                loop
            elif [ "$cycle" = 2 ]; then
                update_check
                fancy_font='Iosevka-Nerd-Font-Complete'
                message="$update_status"
                display_text
                loop
            fi
        fi
    done
    main
}

song_info() {
    [ -n "$wp_timer" ] && unset wp_timer
    song=$(mpc current -f "%title%")
    artist=$(mpc current -f "%artist%")
    album=$(mpc current -f "%album%")
    date=$(mpc current -f "%date%")
    until [ "$state" = "update" ]; do
        if [ "$count" = 100 ]; then
            count=0
            [ "$cycle" = 3 ] && cycle=0 || cycle=$((${cycle} + 1))
        fi
        if [ "$cycle" = 0 ]; then
            fancy_font='Iosevka-Nerd-Font-Complete'
            [ ! "$song" ] && message="’ü▒  missing IDv3 tags" || message="’Ćü  $song"
            display_text
            loop
        elif [ "$cycle" = 1 ]; then
            fancy_font='Iosevka-Nerd-Font-Complete'
            [ ! "$artist" ] && message="’ü▒  missing IDv3 tags" \
                || message="ŌĆÄ’┤üŌĆÄ  $artist"
            display_text
            loop
        elif [ "$cycle" = 2 ]; then
            fancy_font='Iosevka-Nerd-Font-Complete'
            [ ! "$album" ] && message="’ü▒  missing IDv3 tags" || message="’öż  $album"
            display_text
            loop
        elif [ "$cycle" = 3 ]; then
            fancy_font='Iosevka-Nerd-Font-Complete'
            [ ! "$date" ] && message="’ü▒  missing IDv3 tags" \
                || message="ŌĆÄ’««ŌĆÄ  $date"
            display_text
            loop
        fi
    done
    main
}

loop() {
    while [ "$count" -lt 100 ] && [ "$state" != "update" ]; do
        sleep 0.2
        count=$((${count} + 1))
    done
    return
}

display_text() {
    bspc node "$fancy_writing_id" --flag hidden=on
    sleep 0.1
    clear
    fg_color=$(sed -n 16p $XDG_CACHE_HOME/wal/colors)
    length_check=$(echo -n "$message" | wc -c)
    [ "$length_check" -gt 39 ] && final_message=$(echo "$message" | cut -c 1-36 \
        | sed 's/$/.../') || final_message="$message"
    [ "$fancy_font" = 'Victor-Mono-Medium-Italic-Nerd-Font-Complete' ] \
        && font_size=31 || font_size=34
    convert -size 650x200 xc:"transparent" \
        -gravity center \
        -pointsize "$font_size" \
        -font "$fancy_font" \
        -fill "$fg_color" \
        -annotate +0+65 "$final_message" \
        /tmp/fancy_writing.png >/dev/null 2>&1
    kitty +kitten icat /tmp/fancy_writing.png >/dev/null 2>&1
    sleep 0.1
    bspc node "$fancy_writing_id" --flag hidden=off
    return
}

fancy_writing_id=$(xwininfo -root -children | grep -w "fancy writing" | awk '{print $1}')
echo "$fancy_writing_id" >/tmp/fancy_writing_id
wp_timer=$(date +'%s')
main
