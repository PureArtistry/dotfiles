#!/bin/sh

# kills stuff when you stop gaming

running_check(){
	launcher=$(ps aux | grep -e 'steamapps' -e 'lutris/games' | grep -v grep | awk '{print $2}' | head -n1)
	if [ ! $launcher ]; then
		sleep 1
		running_check
	else
		return
	fi
}

pgrep picom >/dev/null && pkill picom
running_check
tail --pid=$launcher -f /dev/null
pgrep steam >/dev/null && kill -HUP $(head -n1 ~/.steampid)
