#!/bin/sh

status=$(nmcli radio wifi)
if [ "$status" = 'enabled' ]; then
    icon='睊'
    nmcli radio wifi off
else
    icon='直'
    nmcli radio wifi on
fi

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf | awk '{print $2}')
b=$(echo "$x" | sed -n 20p)
f=$(echo "$x" | sed -n 2p)
bd=$(echo "$x" | sed -n 18p)

convert -size 75x75 xc:"$b" \
    -gravity center \
    -pointsize "72" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment 'center' &
[ $status = "enabled" ] && dunstify -r "$i" -t 6000 -a 'fancy' "disabled" \
    "\nwifi" -i /tmp/dunst_icon.png \
    || dunstify -r "$i" -t 6000 -a 'fancy' "enabled" "\nwifi" \
        -i /tmp/dunst_icon.png
sleep 3
dunstify -C "$i"
killall -q dunst
