#!/bin/sh

status=$(nmcli radio wifi)
if [ "$status" = 'enabled' ]; then
    icon='睊'
    nmcli radio wifi off
else
    icon='直'
    nmcli radio wifi on
fi

x=$(cat $XDG_CONFIG_HOME/kitty/kitty_colors.conf)
b=$(echo "$x" | awk 'NR==20{print $2}')
f=$(echo "$x" | awk 'NR==2{print $2}')
bd=$(echo "$x" | awk 'NR==18{print $2}')

convert -size 90x90 xc:"$b" \
    -gravity center \
    -pointsize "72" \
    -font "Iosevka-Nerd-Font-Complete" \
    -fill "$f" \
    -bordercolor "$bd" \
    -border '5' \
    -annotate +0+0 "$icon" \
    /tmp/dunst_icon.png >/dev/null 2>&1

i=$(shuf -i 1-10000 -n 1)
pgrep dunst >/dev/null && killall -q dunst
dunst -shrink -alignment 'center' &
[ $status = "enabled" ] && dunstify -r "$i" -t 6000 -a 'fancy1' "disabled" \
    "wifi radio" -i /tmp/dunst_icon.png \
    || dunstify -r "$i" -t 6000 -a 'fancy1' "enabled" "wifi radio" \
        -i /tmp/dunst_icon.png
sleep 3
dunstify -C "$i"
killall -q dunst
