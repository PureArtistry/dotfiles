[ -f /tmp/art_show_id ] && rm -f -v /tmp/art_show_id 2>/dev/null
[ -f /tmp/yt_title ] && rm -f -v /tmp/yt_title 2>/dev/null
[ -f /tmp/rofi_thumb.png ] && rm -f -v /tmp/rofi_thumb.png 2>/dev/null
[ -f /tmp/mctl_id ] && rm -f -v /tmp/mctl_id 2>/dev/null
[ -f /tmp/breadcrumbs ] && rm -f -v /tmp/breadcrumbs 2>/dev/null
[ -f /tmp/dartc.png ] && rm -f -v /tmp/dartc.png 2>/dev/null
[ -f /tmp/dartn.png ] && rm -f -v /tmp/dartn.png 2>/dev/null
[ -f /tmp/fancy_writing_id ] && rm -f -v /tmp/fancy_writing_id 2>/dev/null
[ -f /tmp/fancy_writing.png ] && rm -f -v /tmp/fancy_writing.png 2>/dev/null
[ -f /tmp/companion_id ] && rm -f -v /tmp/companion_id 2>/dev/null
[ -f /tmp/neocover.png ] && rm -f -v /tmp/neocover.png 2>/dev/null
[ -f /tmp/pretty_colours_id ] && rm -f -v /tmp/pretty_colours_id 2>/dev/null
[ -f /tmp/pretty_colours_mode ] && rm -f -v /tmp/pretty_colours_mode 2>/dev/null
[ -f /tmp/startup.tmp ] && rm -f -v /tmp/startup.tmp 2>/dev/null
[ -f /tmp/my_sloc ] && rm -f -v /tmp/my_sloc 2>/dev/null
[ -e /tmp/kitty_control ] && rm -f -v /tmp/kitty_control 2>/dev/null
