alias lsf='exa -alh --time-style=default --color=always --group-directories-first --git'
alias psf='procs'
alias diff='/bin/diff --color=auto'
alias grep='/bin/grep --color=auto'
alias egrep='/bin/egrep --color=auto'
alias fgrep='/bin/fgrep --color=auto'
alias wget='/bin/wget -q --hsts-file="$XDG_CACHE_HOME/wget-hsts" --show-progress --progess=bar:force:noscroll'
alias sudo='sudo '
alias pm='sudo pacman'
alias pmc='sudo pacman -Rns $(pacman -Qtdq)'
alias yay='paru'
alias ':q'='exit'
alias ':Q'='exit'
alias gpd='ghpwd; git push'
alias cls='clear; neofetch'
alias dots='cd $DOTFILES; clear; gitui'
alias cat='bat'
alias task='task 2>/dev/null'
